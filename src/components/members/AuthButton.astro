---
// AuthButton renders a placeholder initially; client-side JS replaces it with auth state.
// Using client:load so it hydrates immediately on every page.
---

<div id="auth-button-root" class="flex items-center">
  <!-- Placeholder to prevent layout shift; replaced by client JS -->
  <div class="w-8 h-8 rounded-full bg-gray-200 dark:bg-gray-700 animate-pulse"></div>
</div>

<script>
  function initAuthButton() {
    const root = document.getElementById('auth-button-root');
    if (!root) return;

    const raw = document.cookie
      .split('; ')
      .find((c) => c.startsWith('user_display='))
      ?.split('=')
      .slice(1)
      .join('=');

    if (raw) {
      try {
        const user = JSON.parse(decodeURIComponent(raw)) as { displayName: string; avatarUrl: string };
        root.innerHTML = `
          <div class="flex items-center gap-2">
            <a href="/profile" title="My Profile" class="flex items-center gap-2 hover:opacity-80 transition-opacity">
              <img
                src="${user.avatarUrl}"
                alt="${user.displayName}"
                width="32"
                height="32"
                class="rounded-full w-8 h-8 object-cover ring-2 ring-primary"
              />
              <span class="hidden lg:inline text-sm font-medium text-gray-700 dark:text-gray-200">${user.displayName}</span>
            </a>
            <a
              href="/api/auth/logout"
              class="text-xs text-gray-500 dark:text-gray-400 hover:text-red-500 dark:hover:text-red-400 transition-colors ml-1"
              title="Sign out"
            >Sign out</a>
          </div>
        `;
        return;
      } catch {
        // fall through to sign-in button
      }
    }

    root.innerHTML = `
      <a
        href="/api/auth/login"
        class="inline-flex items-center gap-1.5 px-4 py-2 text-sm font-semibold rounded-lg bg-primary text-white hover:bg-blue-700 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 127.14 96.36" class="w-4 h-4 fill-current" aria-hidden="true">
          <path d="M107.7,8.07A105.15,105.15,0,0,0,81.47,0a72.06,72.06,0,0,0-3.36,6.83A97.68,97.68,0,0,0,49,6.83,72.37,72.37,0,0,0,45.64,0,105.89,105.89,0,0,0,19.39,8.09C2.79,32.65-1.71,56.6.54,80.21h0A105.73,105.73,0,0,0,32.71,96.36,77.7,77.7,0,0,0,39.6,85.25a68.42,68.42,0,0,1-10.85-5.18c.91-.66,1.8-1.34,2.66-2a75.57,75.57,0,0,0,64.32,0c.87.71,1.76,1.39,2.66,2a68.68,68.68,0,0,1-10.87,5.19,77,77,0,0,0,6.89,11.1A105.25,105.25,0,0,0,126.6,80.22h0C129.24,52.84,122.09,29.11,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53s5-12.74,11.43-12.74S54,46,53.89,53,48.84,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.25,60,73.25,53s5-12.74,11.44-12.74S96.23,46,96.12,53,91.08,65.69,84.69,65.69Z"/>
        </svg>
        Sign in with Discord
      </a>
    `;
  }

  // astro:page-load fires on both initial load and after every View Transitions navigation
  document.addEventListener('astro:page-load', initAuthButton);
</script>

---
import { Icon } from 'astro-icon/components';

interface Props {
  discordId: string;
  displayName: string;
  avatarUrl: string;
  location?: string;
  bio?: string;
  skills?: string[];
  lookingFor?: string[];
}

const { discordId, displayName, avatarUrl, location, bio = '', skills = [], lookingFor = [] } = Astro.props;
const bioPlain = bio.replace(/[*_`~#>[\]]/g, '').trim();

const lookingForLabels: Record<string, string> = {
  jobs: 'Open to work',
  collaborators: 'Seeking collaborators',
  mentors: 'Looking for mentors',
  mentees: 'Open to mentoring',
  'open-source': 'Open source',
};
---

<a
  href={`/members/${discordId}`}
  data-search={`${displayName} ${skills.join(' ')}`.toLowerCase()}
  class="flex flex-col gap-3 p-5 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 hover:shadow-lg hover:border-primary dark:hover:border-primary transition-all group"
>
  <div class="flex items-center gap-3">
    <img
      src={avatarUrl}
      alt={displayName}
      width="48"
      height="48"
      class="rounded-full w-12 h-12 object-cover ring-2 ring-gray-100 dark:ring-gray-700"
      loading="lazy"
    />
    <div class="min-w-0">
      <p class="font-semibold text-gray-900 dark:text-white truncate group-hover:text-primary transition-colors">
        {displayName}
      </p>
      {
        location && (
          <p class="text-sm text-gray-500 dark:text-gray-400 flex items-center gap-1">
            <Icon name="tabler:map-pin" class="w-3.5 h-3.5 shrink-0" />
            <span class="truncate">{location}</span>
          </p>
        )
      }
    </div>
  </div>

  {bioPlain && <p class="text-sm text-gray-600 dark:text-gray-300 line-clamp-2">{bioPlain}</p>}

  {
    skills.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {skills.slice(0, 5).map((skill) => (
          <span class="text-xs px-2 py-0.5 rounded-full bg-blue-50 dark:bg-blue-950 text-blue-700 dark:text-blue-300">
            {skill}
          </span>
        ))}
        {skills.length > 5 && (
          <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-500">
            +{skills.length - 5}
          </span>
        )}
      </div>
    )
  }

  {
    lookingFor.length > 0 && (
      <div class="flex flex-wrap gap-1.5">
        {lookingFor.map((key) => (
          <span class="text-xs px-2 py-0.5 rounded-full bg-purple-50 dark:bg-purple-950 text-purple-700 dark:text-purple-300">
            {lookingForLabels[key] ?? key}
          </span>
        ))}
      </div>
    )
  }
</a>

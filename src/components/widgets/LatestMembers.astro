---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import MemberCard from '~/components/members/MemberCard.astro';
import { db } from '~/lib/firebase';
import type { MemberProfile } from '~/lib/firebase';

interface Props {
  count?: number;
  id?: string;
  isDark?: boolean;
}

const { count = 6, id, isDark = false } = Astro.props;

const snap = await db.collection('members').orderBy('joinedAt', 'desc').get();
const members = snap.docs
  .map((d) => d.data() as MemberProfile)
  .filter((m) => m.emailVerified && m.isPublic)
  .slice(0, count);

if (members.length === 0) return;
---

<WidgetWrapper id={id} isDark={isDark} containerClass="max-w-7xl">
  <div class="flex items-end justify-between mb-8">
    <div>
      <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-1">Community</p>
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Recently Joined</h2>
    </div>
    <a href="/members" class="text-sm font-medium text-primary hover:underline shrink-0 ml-4"> View all members → </a>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
    {
      members.map((m) => (
        <MemberCard
          discordId={m.discordId}
          displayName={m.displayName}
          avatarUrl={m.avatarUrl}
          location={m.location}
          bio={m.bio}
          skills={m.skills}
          lookingFor={m.lookingFor}
        />
      ))
    }
  </div>
</WidgetWrapper>

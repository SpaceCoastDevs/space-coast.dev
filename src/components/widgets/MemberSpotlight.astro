---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { Icon } from 'astro-icon/components';
import { db } from '~/lib/firebase';
import type { MemberProfile } from '~/lib/firebase';

interface Props {
  id?: string;
  isDark?: boolean;
}

const { id, isDark = false } = Astro.props;

const snap = await db.collection('members').where('emailVerified', '==', true).get();
const members = snap.docs.map((d) => d.data() as MemberProfile).filter((m) => m.isPublic);

if (members.length === 0) return;

const member = members[Math.floor(Math.random() * members.length)];

// Plain-text bio excerpt — strip Markdown syntax
const bioText = member.bio.replace(/[*_`~#>[\]()]/g, '').trim();
const bioExcerpt = bioText.slice(0, 200) + (bioText.length > 200 ? '…' : '');

const socialLinks = [
  member.github && { href: `https://github.com/${member.github}`, icon: 'tabler:brand-github', label: 'GitHub' },
  member.linkedin && {
    href: `https://linkedin.com/in/${member.linkedin}`,
    icon: 'tabler:brand-linkedin',
    label: 'LinkedIn',
  },
  member.bluesky && {
    href: `https://bsky.app/profile/${member.bluesky}`,
    icon: 'tabler:brand-bluesky',
    label: 'Bluesky',
  },
  member.website && { href: member.website, icon: 'tabler:world', label: 'Website' },
].filter(Boolean) as { href: string; icon: string; label: string }[];
---

<WidgetWrapper id={id} isDark={isDark} containerClass="max-w-5xl">
  <div class="flex items-end justify-between mb-8">
    <div>
      <p class="text-sm font-semibold uppercase tracking-widest text-primary mb-1">Spotlight</p>
      <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Member Spotlight</h2>
    </div>
    <a href="/members" class="text-sm font-medium text-primary hover:underline shrink-0 ml-4"> Meet everyone → </a>
  </div>

  <a
    href={`/members/${member.discordId}`}
    class="group flex flex-col sm:flex-row gap-6 p-6 rounded-2xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-900 hover:shadow-lg hover:border-primary dark:hover:border-primary transition-all"
  >
    <!-- Avatar -->
    <div class="shrink-0 flex sm:flex-col items-center gap-4 sm:gap-3">
      <img
        src={member.avatarUrl}
        alt={member.displayName}
        width="96"
        height="96"
        class="rounded-full w-20 h-20 sm:w-24 sm:h-24 object-cover ring-4 ring-gray-100 dark:ring-gray-800 group-hover:ring-primary/30 transition-all"
      />
      {
        socialLinks.length > 0 && (
          <div class="flex gap-2">
            {socialLinks.map((link) => (
              <span class="text-gray-400 hover:text-primary transition-colors" title={link.label}>
                <Icon name={link.icon} class="w-4 h-4" />
              </span>
            ))}
          </div>
        )
      }
    </div>

    <!-- Info -->
    <div class="flex-1 min-w-0">
      <div class="flex flex-wrap items-center gap-x-3 gap-y-1 mb-2">
        <h3 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary transition-colors">
          {member.displayName}
        </h3>
        {
          member.location && (
            <span class="text-sm text-gray-500 dark:text-gray-400 flex items-center gap-1">
              <Icon name="tabler:map-pin" class="w-3.5 h-3.5 shrink-0" />
              {member.location}
            </span>
          )
        }
      </div>

      {bioExcerpt && <p class="text-gray-600 dark:text-gray-300 text-sm mb-4 leading-relaxed">{bioExcerpt}</p>}

      {
        member.skills.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {member.skills.slice(0, 8).map((skill) => (
              <span class="text-xs px-2.5 py-0.5 rounded-full bg-blue-50 dark:bg-blue-950 text-blue-700 dark:text-blue-300">
                {skill}
              </span>
            ))}
            {member.skills.length > 8 && (
              <span class="text-xs px-2.5 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-500">
                +{member.skills.length - 8} more
              </span>
            )}
          </div>
        )
      }
    </div>
  </a>
</WidgetWrapper>

---
export const prerender = false;

import PageLayout from '~/layouts/PageLayout.astro';
import { getSession, createSession, buildSessionCookies } from '../../lib/auth';
import { db } from '../../lib/firebase';

const user = await getSession(Astro.request);
if (!user) return Astro.redirect('/api/auth/login');
if (user.emailVerified) return Astro.redirect('/profile');

const doc = await db.collection('members').doc(user.discordId).get();
if (doc.data()?.emailVerified === true) {
  const updatedUser = { ...user, emailVerified: true };
  const token = await createSession(updatedUser);
  const cookies = buildSessionCookies(token, updatedUser);
  const headers = new Headers({ Location: '/profile' });
  cookies.forEach((c) => headers.append('Set-Cookie', c));
  return new Response(null, { status: 302, headers });
}
---

<PageLayout
  metadata={{
    title: 'Enter Verification Code — Space Coast Devs',
    description: 'Enter the code sent to your email to activate your membership.',
  }}
>
  <section class="py-16 md:py-24">
    <div class="max-w-md mx-auto px-4">
      <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 p-8">
        <div class="text-center mb-8">
          <div
            class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-green-50 dark:bg-green-950 mb-4"
          >
            <svg
              class="w-7 h-7 text-green-600 dark:text-green-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Check your inbox</h1>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
            We sent a 6-digit code to your email. Enter it below — it expires in 15 minutes.
          </p>
        </div>

        <div
          id="error-msg"
          class="hidden mb-4 rounded-lg bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 px-4 py-3 text-sm text-red-700 dark:text-red-300"
        >
        </div>

        <div class="space-y-4">
          <div>
            <label for="code" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Verification code
            </label>
            <input
              id="code"
              type="text"
              inputmode="numeric"
              autocomplete="one-time-code"
              maxlength="6"
              placeholder="123456"
              class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 px-4 py-3 text-2xl text-center tracking-[0.4em] font-mono text-gray-900 dark:text-white placeholder-gray-300 focus:outline-none focus:ring-2 focus:ring-green-500"
            />
          </div>

          <button
            id="verify-btn"
            type="button"
            class="w-full rounded-lg bg-green-600 hover:bg-green-700 disabled:opacity-60 text-white font-medium py-2.5 text-sm transition-colors"
          >
            Verify and activate
          </button>
        </div>

        <p class="text-center text-xs text-gray-400 dark:text-gray-500 mt-6">
          Didn't get the code?
          <a href="/verify-email" class="underline hover:text-primary">Send a new one</a>
        </p>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const codeInput = document.getElementById('code') as HTMLInputElement;
  const verifyBtn = document.getElementById('verify-btn') as HTMLButtonElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;

  // Auto-submit when 6 digits are entered
  codeInput.addEventListener('input', () => {
    codeInput.value = codeInput.value.replace(/\D/g, '').slice(0, 6);
    if (codeInput.value.length === 6) verifyBtn.click();
  });

  function showError(msg: string) {
    errorMsg.textContent = msg;
    errorMsg.classList.remove('hidden');
  }

  verifyBtn.addEventListener('click', async () => {
    const code = codeInput.value.trim();
    if (code.length !== 6) {
      showError('Please enter the 6-digit code from your email.');
      return;
    }

    errorMsg.classList.add('hidden');
    verifyBtn.disabled = true;
    verifyBtn.textContent = 'Verifying…';

    try {
      const res = await fetch('/api/auth/verify-code', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ code }),
      });

      const data = (await res.json()) as { ok?: boolean; error?: string };

      if (!res.ok) {
        showError(data.error ?? 'Something went wrong. Please try again.');
        verifyBtn.disabled = false;
        verifyBtn.textContent = 'Verify and activate';
        codeInput.value = '';
        codeInput.focus();
        return;
      }

      window.location.href = '/profile';
    } catch {
      showError('Network error. Please try again.');
      verifyBtn.disabled = false;
      verifyBtn.textContent = 'Verify and activate';
    }
  });
</script>

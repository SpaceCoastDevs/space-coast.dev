---
export const prerender = false;

import PageLayout from '~/layouts/PageLayout.astro';
import { getSession, createSession, buildSessionCookies } from '../../lib/auth';
import { db } from '../../lib/firebase';

const user = await getSession(Astro.request);
if (!user) return Astro.redirect('/api/auth/login');
if (user.emailVerified) return Astro.redirect('/profile');

// JWT may be stale — check Firestore as the source of truth
const doc = await db.collection('members').doc(user.discordId).get();
if (doc.data()?.emailVerified === true) {
  const updatedUser = { ...user, emailVerified: true };
  const token = await createSession(updatedUser);
  const cookies = buildSessionCookies(token, updatedUser);
  const headers = new Headers({ Location: '/profile' });
  cookies.forEach((c) => headers.append('Set-Cookie', c));
  return new Response(null, { status: 302, headers });
}
---

<PageLayout
  metadata={{
    title: 'Verify Your Email — Space Coast Devs',
    description: 'Verify your email to activate your Space Coast Devs membership.',
  }}
>
  <section class="py-16 md:py-24">
    <div class="max-w-md mx-auto px-4">
      <div class="bg-white dark:bg-slate-900 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-800 p-8">
        <div class="text-center mb-8">
          <div class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-blue-50 dark:bg-blue-950 mb-4">
            <svg class="w-7 h-7 text-blue-600 dark:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Verify your email</h1>
          <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">
            Enter your email address and we'll send you a 6-digit verification code.
          </p>
        </div>

        <div
          id="error-msg"
          class="hidden mb-4 rounded-lg bg-red-50 dark:bg-red-950 border border-red-200 dark:border-red-800 px-4 py-3 text-sm text-red-700 dark:text-red-300"
        >
        </div>

        <div class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">
              Email address
            </label>
            <input
              id="email"
              type="email"
              autocomplete="email"
              placeholder="you@example.com"
              class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-slate-800 px-4 py-2.5 text-sm text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500"
            />
          </div>

          <button
            id="send-btn"
            type="button"
            class="w-full rounded-lg bg-blue-600 hover:bg-blue-700 disabled:opacity-60 text-white font-medium py-2.5 text-sm transition-colors"
          >
            Send verification code
          </button>
        </div>

        <p class="text-center text-xs text-gray-400 dark:text-gray-500 mt-6">
          Signed in as <strong class="text-gray-600 dark:text-gray-300">{user.displayName}</strong> via Discord.
          <a href="/api/auth/logout" class="underline hover:text-primary ml-1">Sign out</a>
        </p>
      </div>
    </div>
  </section>
</PageLayout>

<script>
  const emailInput = document.getElementById('email') as HTMLInputElement;
  const sendBtn = document.getElementById('send-btn') as HTMLButtonElement;
  const errorMsg = document.getElementById('error-msg') as HTMLDivElement;

  function showError(msg: string) {
    errorMsg.textContent = msg;
    errorMsg.classList.remove('hidden');
  }

  sendBtn.addEventListener('click', async () => {
    const email = emailInput.value.trim();
    if (!email) {
      showError('Please enter your email address.');
      return;
    }

    errorMsg.classList.add('hidden');
    sendBtn.disabled = true;
    sendBtn.textContent = 'Sending…';

    try {
      const res = await fetch('/api/auth/send-verification', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      const data = (await res.json()) as { ok?: boolean; error?: string };

      if (!res.ok) {
        showError(data.error ?? 'Something went wrong. Please try again.');
        sendBtn.disabled = false;
        sendBtn.textContent = 'Send verification code';
        return;
      }

      window.location.href = '/verify-email/check';
    } catch {
      showError('Network error. Please try again.');
      sendBtn.disabled = false;
      sendBtn.textContent = 'Send verification code';
    }
  });

  emailInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') sendBtn.click();
  });
</script>

# Discord OAuth Application
# Create at https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:4321/api/auth/callback
# Find your Guild ID: Server Settings > Widget > Server ID
DISCORD_GUILD_ID=

# Firebase Service Account
# Generate at: Firebase Console > Project Settings > Service Accounts > Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the full private key including -----BEGIN/END----- headers
# On Netlify, use the literal string with \n — the app will replace them at runtime
FIREBASE_PRIVATE_KEY=

# Session signing secret (generate with: openssl rand -base64 32)
SESSION_SECRET=

# Gmail SMTP — for sending email verification codes
# Use a Gmail App Password: https://myaccount.google.com/apppasswords
GMAIL_USER=noreply@yourdomain.com
GMAIL_APP_PASSWORD=
